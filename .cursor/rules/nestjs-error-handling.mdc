### Error Enum + Message Map

#### Good

```typescript
// application/shared/errors/auth.errors.ts
export enum AuthError {
  USER_NOT_FOUND = 'AUTH_USER_NOT_FOUND',
  EMAIL_EXISTS = 'AUTH_EMAIL_EXISTS',
  INVALID_CREDENTIALS = 'AUTH_INVALID_CREDENTIALS',
  TOKEN_EXPIRED = 'AUTH_TOKEN_EXPIRED',
  UNAUTHORIZED = 'AUTH_UNAUTHORIZED',
}

export const AuthErrorMessage: Record<AuthError, string> = {
  [AuthError.USER_NOT_FOUND]: 'User not found',
  [AuthError.EMAIL_EXISTS]: 'A user with this email already exists',
  [AuthError.INVALID_CREDENTIALS]: 'Invalid email or password',
  [AuthError.TOKEN_EXPIRED]: 'Authentication token has expired',
  [AuthError.UNAUTHORIZED]: 'You are not authorized to perform this action',
};
```

### Error Type URIs

```typescript
// application/shared/errors/error-types.ts
import { AuthError } from './auth.errors';
import { ProfileError } from './profile.errors';

const BASE = 'https://api.yourapp.com/errors';

export const ErrorType: Record<string, string> = {
  // Auth errors
  [AuthError.USER_NOT_FOUND]: `${BASE}/auth/user-not-found`,
  [AuthError.EMAIL_EXISTS]: `${BASE}/auth/email-exists`,
  [AuthError.INVALID_CREDENTIALS]: `${BASE}/auth/invalid-credentials`,
  [AuthError.TOKEN_EXPIRED]: `${BASE}/auth/token-expired`,
  [AuthError.UNAUTHORIZED]: `${BASE}/auth/unauthorized`,

  // Profile errors
  [ProfileError.NOT_FOUND]: `${BASE}/profile/not-found`,
  [ProfileError.UPDATE_FAILED]: `${BASE}/profile/update-failed`,
};
```

